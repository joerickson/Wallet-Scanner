# Required
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket API base URLs (configurable for testing or API migration)
POLYMARKET_DATA_API_BASE=https://data-api.polymarket.com
POLYMARKET_GAMMA_API_BASE=https://gamma-api.polymarket.com

# Scanner tuning
API_RATE_LIMIT=2.0          # max requests per second
MIN_TRADES=100              # hard filter: minimum lifetime trades
MIN_WIN_RATE=0.60           # hard filter: minimum win rate
MIN_VOLUME_USD=5000.0       # hard filter: minimum total USDC volume
SHARPE_MIN_TRADES=90        # minimum trades required to compute Sharpe ratio
CLAUDE_REVIEW_TOP_N=200     # wallets sent to Claude for qualitative review

# Composite ranking weights (must sum to 1.0)
WEIGHT_WIN_RATE=0.30
WEIGHT_SHARPE=0.25
WEIGHT_PROFIT_FACTOR=0.20
WEIGHT_TOTAL_PNL=0.15
WEIGHT_TRADE_COUNT=0.10

# Cache TTLs (seconds)
WALLET_CACHE_TTL=86400      # 24 hours for wallet scan freshness
API_CACHE_TTL=3600          # 1 hour for raw API response cache

# Watch / alert system
POLL_INTERVAL=300           # seconds between position polls (default: 5 min)

# Optional webhook alerts (leave blank to disable)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
