{
  "version": 2,
  "buildCommand": "cd dashboard && npm install && npm run build",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/**",
          "data/**",
          "scanner/**",
          "dashboard/dist/**",
          "config.py"
        ]
      }
    }
  ],
  "crons": [
    { "path": "/api/cron/advance-paper-tests", "schedule": "*/5 * * * *" }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
